# LINE Messaging API
# 取得方式:LINE Developers Console -> 你的 channel -> Messaging API -> Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=your_long_lived_channel_access_token_here

# 取得方式:LINE Developers Console -> 你的 channel -> Basic settings -> Channel secret
LINE_CHANNEL_SECRET=your_channel_secret_here

# Gemini API
# 取得方式:https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (可選)指定模型,預設 gemini-2.5-flash-lite;可改成 gemini-1.5-flash 等
# GEMINI_MODEL=gemini-2.5-flash-lite
